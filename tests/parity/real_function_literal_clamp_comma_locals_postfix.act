REAL CONST NEG_ONE=-1.0
REAL CONST ZERO=0.0
REAL CONST ONE=1.0
MODULE MAIN
REAL INPUT
REAL LOW_RESULT
REAL ZERO_RESULT
REAL HIGH_RESULT
REAL FUNC LIMIT(REAL VALUE)
REAL PRODUCT,LOWER,UPPER,ZEROLOCAL
LOWER=NEG_ONE
UPPER=ONE
ZEROLOCAL=ZERO
PRODUCT=VALUE*UPPER
IF PRODUCT<LOWER THEN
RETURN(LOWER)
FI
IF PRODUCT>UPPER THEN
RETURN(UPPER)
FI
IF PRODUCT=ZEROLOCAL THEN
RETURN(ZEROLOCAL)
FI
RETURN(PRODUCT)
PROC MAIN()
INPUT=REAL(0-2)
LOW_RESULT=LIMIT(INPUT)
INPUT=REAL(0)
ZERO_RESULT=LIMIT(INPUT)
INPUT=REAL(2)
HIGH_RESULT=LIMIT(INPUT)
PrintRE(LOW_RESULT)
PrintRE(ZERO_RESULT)
PrintRE(HIGH_RESULT)
RETURN
