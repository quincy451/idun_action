MODULE MAIN
REAL START
REAL LIMIT
REAL FIRST
REAL SECOND
REAL FUNC UP(REAL A,B)
DO
A=B
UNTIL A>=B
OD
RETURN(A)
REAL FUNC DOWN(REAL A,B)
WHILE A>B DO
A=B
OD
RETURN(A)
PROC MAIN()
START=REAL(1)
LIMIT=REAL(4)
FIRST=UP(START,LIMIT)
START=REAL(7)
LIMIT=REAL(3)
SECOND=DOWN(START,LIMIT)
PrintRE(FIRST)
PrintRE(SECOND)
RETURN
