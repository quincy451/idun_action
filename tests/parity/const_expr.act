CARD CONST PRECEDENCE=2+3*4
CARD CONST GROUPED=(2+3)*4
CARD CONST DIVMOD=(100/7)+(100 MOD 7)
CARD CONST SHIFT=(1 LSH 15) RSH 7
CARD CONST BITS=(($F0 & $CC) % $03) XOR $02
INT CONST SIGNED=(-7*3)/2
INT CONST REMAINDER=(-20) MOD 3
BYTE CONST CHARACTER='A'+1
CARD CONST CHEX=0x1234
CARD CONST MIXED=-3+5
CARD CONST MASK=-1 & $FFFF
CARD CONST WIDE=(65535*65535)/65535
CARD CONST HIGH=(1 LSH 62) RSH 47
CARD CONST NEGSHIFT=(-1 RSH 48)
BYTE CONST BUTTONS=JOY_UP % JOY_BUTTON1
MODULE MAIN
CARD PRECEDENCE_OUT=[PRECEDENCE]
CARD GROUPED_OUT=[GROUPED]
CARD DIVMOD_OUT=[DIVMOD]
CARD SHIFT_OUT=[SHIFT]
CARD BITS_OUT=[BITS]
INT SIGNED_OUT=[SIGNED]
INT REMAINDER_OUT=[REMAINDER]
BYTE CHARACTER_OUT=[CHARACTER]
CARD CHEX_OUT=[CHEX]
CARD MIXED_OUT=[MIXED]
CARD MASK_OUT=[MASK]
CARD WIDE_OUT=[WIDE]
CARD HIGH_OUT=[HIGH]
CARD NEGSHIFT_OUT=[NEGSHIFT]
BYTE BUTTONS_OUT=[BUTTONS]
PROC MAIN()
RETURN
ENDPROC
