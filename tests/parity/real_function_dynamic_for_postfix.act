MODULE MAIN
REAL START
REAL DELTA
REAL LOWER
REAL UPPER
REAL FUNC FROMOUTER(REAL A,B)
CARD I
CARD J
REAL TOTAL
TOTAL=A
FOR I=1 TO 3
DO
FOR J=I TO 3
DO
TOTAL=TOTAL+B
OD
OD
RETURN(TOTAL)
REAL FUNC TOOUTER(REAL A,B)
CARD K
CARD L
REAL TOTAL2
TOTAL2=A
FOR K=1 TO 3
DO
FOR L=1 TO K
DO
TOTAL2=TOTAL2+B
OD
OD
RETURN(TOTAL2)
PROC MAIN()
START=REAL(1)
DELTA=REAL(1)
LOWER=FROMOUTER(START,DELTA)
UPPER=TOOUTER(START,DELTA)
PrintRE(LOWER)
PrintRE(UPPER)
RETURN
