MODULE MAIN
REAL LEFT
REAL RIGHT
REAL FIRST
REAL SECOND
REAL THIRD
REAL FUNC PICK(REAL A,B)
REAL CHOICE
IF A<B THEN
IF A<REAL(2) THEN
CHOICE=FMin(A,B)
ELSE
CHOICE=FMax(A,B)
FI
ELSE
CHOICE=FMin(A,B)
FI
RETURN(CHOICE)
PROC MAIN()
LEFT=REAL(1)
RIGHT=REAL(4)
FIRST=PICK(LEFT,RIGHT)
LEFT=REAL(3)
SECOND=PICK(LEFT,RIGHT)
LEFT=REAL(4)
RIGHT=REAL(3)
THIRD=PICK(LEFT,RIGHT)
PrintRE(FIRST)
PrintRE(SECOND)
PrintRE(THIRD)
RETURN
