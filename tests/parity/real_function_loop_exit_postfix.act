MODULE MAIN
REAL START
REAL LIMIT
REAL FIRST
REAL SECOND
REAL FUNC PLAIN(REAL A,B)
DO
A=B
EXIT
OD
RETURN(A)
REAL FUNC GUARDED(REAL A,B)
WHILE A>B DO
A=B
EXIT
OD
RETURN(A)
PROC MAIN()
START=REAL(1)
LIMIT=REAL(4)
FIRST=PLAIN(START,LIMIT)
START=REAL(7)
LIMIT=REAL(3)
SECOND=GUARDED(START,LIMIT)
PrintRE(FIRST)
PrintRE(SECOND)
RETURN
