REAL CONST MATH_PI=3.14159265358979323846
MODULE MAIN
REAL DEGREES
REAL PI_VALUE
REAL RADIANS
REAL RESULT_DEGREES
REAL FUNC DEGTORAD(REAL VALUE)
REAL FORWARD_FACTOR
REAL FORWARD_DIVISOR
FORWARD_FACTOR=MATH_PI
FORWARD_DIVISOR=REAL(180)
FORWARD_FACTOR=FORWARD_FACTOR/FORWARD_DIVISOR
RETURN(VALUE*FORWARD_FACTOR)
REAL FUNC RADTODEG(REAL VALUE)
REAL REVERSE_FACTOR
REAL REVERSE_DIVISOR
REVERSE_FACTOR=REAL(180)
REVERSE_DIVISOR=MATH_PI
REVERSE_FACTOR=REVERSE_FACTOR/REVERSE_DIVISOR
RETURN(VALUE*REVERSE_FACTOR)
PROC MAIN()
DEGREES=REAL(180)
PI_VALUE=MATH_PI
RADIANS=DEGTORAD(DEGREES)
RESULT_DEGREES=RADTODEG(PI_VALUE)
PrintRE(RADIANS)
PrintRE(RESULT_DEGREES)
RETURN
