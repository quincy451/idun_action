MODULE MAIN
REAL START
REAL DELTA
REAL ASCENDING
REAL DESCENDING
REAL FUNC ASCEND(REAL A,B)
CARD I
REAL TOTAL
TOTAL=A
FOR I=1 TO 3
DO
TOTAL=TOTAL+B
OD
RETURN(TOTAL)
REAL FUNC DESCEND(REAL A,B)
CARD J
REAL TOTAL2
TOTAL2=A
FOR J=5 TO 1 STEP -2
DO
TOTAL2=TOTAL2+B
OD
RETURN(TOTAL2)
PROC MAIN()
START=REAL(1)
DELTA=REAL(1)
ASCENDING=ASCEND(START,DELTA)
DELTA=REAL(2)
DESCENDING=DESCEND(START,DELTA)
PrintRE(ASCENDING)
PrintRE(DESCENDING)
RETURN
