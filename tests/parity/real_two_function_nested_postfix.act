MODULE MAIN
REAL LEFT
REAL RIGHT
REAL LONGRESULT
REAL SHORTRESULT
REAL FUNC LENGTH(REAL A,B)
REAL ABSLEFT
ABSLEFT=FAbs(A)
RETURN(FHypot(ABSLEFT,FAbs(B)))
REAL FUNC SHORTER(REAL A,B)
REAL ABSRIGHT
ABSRIGHT=FAbs(B)
RETURN(FMin(FAbs(A),ABSRIGHT))
PROC MAIN()
LEFT=REAL(3)
RIGHT=REAL(4)
LONGRESULT=LENGTH(LEFT,RIGHT)
SHORTRESULT=SHORTER(LEFT,RIGHT)
PrintRE(LONGRESULT)
PrintRE(SHORTRESULT)
RETURN
