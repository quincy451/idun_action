MODULE MAIN
REAL LEFT
REAL RIGHT
REAL FIRST
REAL SECOND
REAL FUNC PICK(REAL A,B)
REAL CHOICE
CHOICE=B
IF A<B THEN
CHOICE=A
FI
IF A<B THEN
CHOICE=B
FI
IF A<B THEN
CHOICE=A
FI
IF A<B THEN
CHOICE=B
FI
RETURN(CHOICE)
PROC MAIN()
LEFT=REAL(3)
RIGHT=REAL(4)
FIRST=PICK(LEFT,RIGHT)
SECOND=PICK(RIGHT,LEFT)
PrintRE(FIRST)
PrintRE(SECOND)
RETURN
