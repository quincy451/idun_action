MODULE MAIN
REAL LEFT
REAL RIGHT
REAL FIRST
REAL SECOND
REAL THIRD
REAL FUNC PICK(REAL A,B)
REAL CHOICE
CHOICE=B
IF A<B THEN
IF A<REAL(4) THEN
IF A<REAL(3) THEN
IF A<REAL(2) THEN
CHOICE=A
ELSE
CHOICE=B
FI
FI
FI
FI
RETURN(CHOICE)
PROC MAIN()
LEFT=REAL(1)
RIGHT=REAL(5)
FIRST=PICK(LEFT,RIGHT)
LEFT=REAL(2)
SECOND=PICK(LEFT,RIGHT)
LEFT=REAL(5)
RIGHT=REAL(4)
THIRD=PICK(LEFT,RIGHT)
PrintRE(FIRST)
PrintRE(SECOND)
PrintRE(THIRD)
RETURN
